    "render:phala-hub-env": "node scripts/render-phala-hub-env.mjs --output deploy/phala/morpheus.hub.env",
    "verify:cloudflare-token": "node scripts/verify-cloudflare-token.mjs",
    "verify:edge-gateway": "node scripts/verify-edge-gateway.mjs",
    "check:checkly": "node scripts/checkly-list-checks.mjs",
    "sync:checkly": "node scripts/checkly-sync-api-checks.mjs",
    "sync:checkly:browser": "node scripts/checkly-sync-browser-checks.mjs",
    "check:betterstack": "node scripts/betterstack-list-heartbeats.mjs",
    "sync:betterstack": "node scripts/betterstack-sync-heartbeats.mjs",
    "check:betterstack:monitors": "node scripts/betterstack-list-monitors.mjs",
    "sync:betterstack:monitors": "node scripts/betterstack-sync-monitors.mjs",
    "check:betterstack:sources": "node scripts/betterstack-list-sources.mjs",
    "sync:betterstack:sources": "node scripts/betterstack-sync-sources.mjs",
    "export:saas": "node scripts/export-saas-inventory.mjs",
    "smoke:control-plane": "node scripts/smoke-control-plane.mjs",
    "stress:runtime": "node scripts/stress-oracle-runtime.mjs",
    "backup:system": "node scripts/backup-system-state.mjs",
    "start:testnet-rng-local": "bash scripts/run-testnet-rng-local.sh",
    "check:env": "node scripts/check-root-env.mjs",
    "check:control-plane": "node scripts/check-control-plane-env.mjs",
    "check:control-plane:strict": "node scripts/check-control-plane-env.mjs --strict",
    "check:signers": "node scripts/check-neo-signers.mjs",
    "check:phala-env": "node scripts/check-phala-env.mjs",
    "test:control-plane": "node --test deploy/cloudflare/morpheus-control-plane/worker.test.mjs",
    "test:testnet:local-gates": "bash scripts/run_local_validation_gates.sh",
    "test:testnet:live": "bash scripts/run_live_testnet_validation.sh",
    "test:testnet:full": "bash scripts/run_full_testnet_validation.sh",
    "test:workspace:local": "bash scripts/run_workspace_local_validation.sh",
    "test:workspace:live": "bash scripts/run_workspace_live_validation.sh",
    "test:workspace:full": "bash scripts/run_workspace_full_validation.sh",
    "compile:neox": "npm --prefix contracts/neox run compile",
    "test:neox": "npm --prefix contracts/neox test",
    "test:scripts": "node --test scripts/*.test.mjs"
  },
  "devDependencies": {
    "@typescript-eslint/eslint-plugin": "^8.57.1",
    "@typescript-eslint/parser": "^8.57.1",
    "eslint": "^8.57.0",
    "prettier": "^3.3.0"
  },
  "overrides": {
    "h3": {
      ".": "1.15.9",
      "defu": "6.1.7"
    },
    "socket.io-parser": "4.2.6",
    "anymatch": {
      "picomatch": "2.3.2"
    },
    "readdirp": {
      "picomatch": "2.3.2"
    },
    "tinyglobby": {
      "picomatch": "4.0.4",
      "fdir": {
        "picomatch": "4.0.4"
      }
    }
  }
}
