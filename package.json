{
  "name": "neo-morpheus-oracle",
  "private": true,
  "workspaces": [
    "apps/*",
    "workers/*",
    "packages/*"
  ],
  "scripts": {
    "lint": "eslint . --ext .js,.mjs,.ts,.tsx",
    "lint:fix": "eslint . --ext .js,.mjs,.ts,.tsx --fix",
    "format": "prettier --write \"**/*.{js,mjs,ts,tsx,json,md,yml,yaml}\"",
    "format:check": "prettier --check \"**/*.{js,mjs,ts,tsx,json,md,yml,yaml}\"",
    "dev:web": "npm --prefix apps/web run dev",
    "build:web": "npm --prefix apps/web run build",
    "check:web-content": "node scripts/check-web-consistency.mjs",
    "start:web": "npm --prefix apps/web run start",
    "check:worker": "npm --prefix workers/phala-worker run check",
    "test:worker": "npm --prefix workers/phala-worker test",
    "check:relayer": "npm --prefix workers/morpheus-relayer run check",
    "test:relayer": "npm --prefix workers/morpheus-relayer test",
    "start:relayer": "npm --prefix workers/morpheus-relayer run start",
    "once:relayer": "npm --prefix workers/morpheus-relayer run once",
    "metrics:relayer": "npm --prefix workers/morpheus-relayer run metrics",
    "metrics:relayer:prom": "npm --prefix workers/morpheus-relayer run metrics:prom",
    "start:relayer:metrics": "npm --prefix workers/morpheus-relayer run serve:metrics",
    "publish:oracle-key": "node scripts/publish-oracle-public-key.mjs",
    "publish:oracle-key:neox": "node scripts/publish-oracle-public-key-neox.mjs",
    "publish:oracle-verifier-key": "node scripts/publish-oracle-verifier-key.mjs",
    "publish:oracle-verifier-key:neox": "node scripts/publish-oracle-verifier-key-neox.mjs",
    "upgrade:datafeed:n3": "node scripts/upgrade-morpheus-datafeed.mjs",
    "audit:feeds": "node scripts/audit-feed-freshness.mjs",
    "backfill:feeds": "node scripts/backfill-feed-pairs.mjs",
    "write:addresses": "node scripts/write-address-registry.mjs",
    "verify:n3": "node scripts/verify-morpheus-n3.mjs",
    "set:updater:n3": "node scripts/set-neo-n3-updater.mjs",
    "smoke:n3": "node scripts/smoke-oracle-n3.mjs",
    "verify:neox": "node scripts/verify-morpheus-neox.mjs",
    "smoke:neox": "node scripts/smoke-oracle-neox.mjs",
    "smoke:all": "node scripts/smoke-all.mjs",
    "examples:deploy:neox": "node examples/scripts/deploy-neox-examples.mjs",
    "examples:test:neox": "node examples/scripts/test-neox-examples.mjs",
    "examples:test:neox:builtins": "node examples/scripts/test-neox-builtins.mjs",
    "examples:deploy:n3": "node examples/scripts/deploy-n3-examples.mjs",
    "examples:test:n3": "node examples/scripts/test-n3-examples.mjs",
    "examples:test:n3:neodid": "node examples/scripts/test-n3-neodid-oracle-matrix.mjs",
    "examples:test:n3:privacy": "node examples/scripts/test-n3-privacy-matrix.mjs",
    "examples:test:n3:automation": "node examples/scripts/test-n3-automation.mjs",
    "examples:test:n3:builtins": "node examples/scripts/test-n3-builtins.mjs",
    "examples:test:n3:callback-boundary": "node examples/scripts/test-n3-callback-boundary.mjs",
    "examples:test:n3:aa-callback-replay-boundary": "node examples/scripts/test-n3-aa-callback-replay-boundary.mjs",
    "examples:test:n3:aa-session-oracle-boundary": "node examples/scripts/test-n3-aa-session-oracle-boundary.mjs",
    "examples:test:n3:neodid-registry-boundary": "node examples/scripts/test-n3-neodid-registry-boundary.mjs",
    "examples:test:n3:neodid-registry-v1": "node examples/scripts/test-n3-neodid-registry-v1.mjs",
    "examples:test:n3:encrypted-ref-boundary": "node examples/scripts/test-n3-encrypted-ref-boundary.mjs",
    "examples:test:n3:automation-deposit-exhaustion": "node examples/scripts/test-n3-automation-deposit-exhaustion.mjs",
    "examples:test:n3:fulfillment-replay": "node examples/scripts/test-n3-fulfillment-replay-isolated.mjs",
    "examples:test:n3:attack-regression": "node examples/scripts/test-n3-integrated-attack-regression.mjs",
    "examples:test:feed-source": "node examples/scripts/validate-feed-source-mappings.mjs",
    "examples:test:all": "node examples/scripts/test-all-examples.mjs",
    "examples:live": "node examples/scripts/deploy-and-test-all.mjs",
    "examples:all": "node examples/scripts/deploy-and-test-all.mjs",
    "render:phala-env": "node scripts/render-phala-env.mjs --network mainnet --output deploy/phala/morpheus.mainnet.env",
    "render:phala-env:testnet": "node scripts/render-phala-env.mjs --network testnet --output deploy/phala/morpheus.testnet.env",
