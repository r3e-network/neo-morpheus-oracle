{
  "name": "neo-morpheus-oracle",
  "private": true,
  "workspaces": [
    "apps/*",
    "workers/*",
    "packages/*"
  ],
  "scripts": {
    "dev:web": "npm --prefix apps/web run dev",
    "build:web": "npm --prefix apps/web run build",
    "start:web": "npm --prefix apps/web run start",
    "check:worker": "npm --prefix workers/phala-worker run check",
    "test:worker": "npm --prefix workers/phala-worker test",
    "check:relayer": "npm --prefix workers/morpheus-relayer run check",
    "test:relayer": "npm --prefix workers/morpheus-relayer test",
    "start:relayer": "npm --prefix workers/morpheus-relayer run start",
    "once:relayer": "npm --prefix workers/morpheus-relayer run once",
    "metrics:relayer": "npm --prefix workers/morpheus-relayer run metrics",
    "publish:oracle-key": "node scripts/publish-oracle-public-key.mjs",
    "write:addresses": "node scripts/write-address-registry.mjs",
    "compile:neox": "npm --prefix contracts/neox run compile",
    "test:neox": "npm --prefix contracts/neox test"
  }
}
