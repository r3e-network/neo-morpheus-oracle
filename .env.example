# Morpheus Oracle / 墨菲斯网络
# Quick guide / 快速说明:
# - The variables below are grouped by function.
# - For a bilingual explanation of what each variable does, read `docs/ENVIRONMENT.md`.
# - If you are unsure, fill the required contract addresses, RPC URLs, signing keys, Phala auth, and Supabase credentials first.

# Web / Vercel / 前端与公共入口
NEXT_PUBLIC_APP_NAME=Morpheus Oracle
NEXT_PUBLIC_APP_URL=http://localhost:3000
NEXT_PUBLIC_MORPHEUS_NETWORK=testnet
PHALA_API_URL=https://your-phala-worker.example.com
PHALA_API_TOKEN=your-phala-api-token
PHALA_SHARED_SECRET=your-phala-shared-secret
TWELVEDATA_API_KEY=
ORACLE_TIMEOUT=20s
ORACLE_SCRIPT_TIMEOUT_MS=2000
COMPUTE_SCRIPT_TIMEOUT_MS=2000
PHALA_USE_DERIVED_KEYS=false
PHALA_EMIT_ATTESTATION=false
PHALA_DSTACK_ENDPOINT=
PHALA_DSTACK_NEO_N3_KEY_PATH=
PHALA_DSTACK_NEOX_KEY_PATH=
MORPHEUS_FEED_PROJECT_SLUG=
MORPHEUS_FEED_PROVIDER=twelvedata
MORPHEUS_FEED_PROVIDERS=twelvedata,binance-spot
MORPHEUS_FEED_SYMBOLS=NEO-USD,GAS-USD,1000FLM-USD,BTC-USD,ETH-USD,SOL-USD,TRX-USD,PAXG-USD,WTI-USD,BRENT-USD,NATGAS-USD,COPPER-USD,WHEAT-USD,CORN-USD,SOY-USD,USDT-USD,USDC-USD,BNB-USD,XRP-USD,DOGE-USD,AAPL-USD,GOOGL-USD,MSFT-USD,AMZN-USD,TSLA-USD,META-USD,NVDA-USD,SPY-USD,QQQ-USD,GLD-USD,EUR-USD,GBP-USD,1000JPY-USD,CNY-USD
MORPHEUS_FEED_CHANGE_THRESHOLD_BPS=10
MORPHEUS_FEED_MIN_UPDATE_INTERVAL_MS=15000
MORPHEUS_FEED_PAIR_REGISTRY_JSON=
MORPHEUS_NETWORK=testnet
MORPHEUS_RELAYER_POLL_INTERVAL_MS=5000
MORPHEUS_RELAYER_CONCURRENCY=4
MORPHEUS_RELAYER_MAX_BLOCKS_PER_TICK=250
MORPHEUS_RELAYER_MAX_RETRIES=5
MORPHEUS_RELAYER_RETRY_BASE_DELAY_MS=5000
MORPHEUS_RELAYER_RETRY_MAX_DELAY_MS=300000
MORPHEUS_RELAYER_NEO_N3_START_BLOCK=
MORPHEUS_RELAYER_NEO_X_START_BLOCK=
MORPHEUS_RELAYER_PROCESSED_CACHE_SIZE=5000
MORPHEUS_RELAYER_DEAD_LETTER_LIMIT=500
MORPHEUS_AUTOMATION_ENABLED=true
MORPHEUS_AUTOMATION_BATCH_SIZE=50
MORPHEUS_AUTOMATION_MAX_QUEUED_PER_TICK=10
MORPHEUS_AUTOMATION_PRICE_PAIRS_PER_TICK=64
MORPHEUS_AUTOMATION_DEFAULT_PRICE_COOLDOWN_MS=60000
MORPHEUS_RELAYER_LOG_FORMAT=json
MORPHEUS_RELAYER_LOG_LEVEL=info
MORPHEUS_RELAYER_NEO_N3_WIF=
MORPHEUS_RELAYER_NEO_N3_PRIVATE_KEY=
MORPHEUS_RELAYER_NEOX_PRIVATE_KEY=

# Supabase / Supabase 服务端访问
NEXT_PUBLIC_SUPABASE_URL=https://your-project.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-anon-key
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key
MORPHEUS_PROVIDER_CONFIG_API_KEY=
MORPHEUS_RELAYER_ADMIN_API_KEY=
MORPHEUS_SIGNING_ADMIN_API_KEY=
MORPHEUS_RELAY_ADMIN_API_KEY=
MORPHEUS_OPERATOR_API_KEY=

# Neo N3 / Neo X / 链 RPC 与网络参数
NEO_RPC_URL=https://testnet1.neo.coz.io:443
NEO_NETWORK_MAGIC=894710606
NEOX_RPC_URL=https://neoxt4seed1.ngd.network
NEOX_CHAIN_ID=12227332

# Signing / relay keys (Phala worker) / Worker 与 Relayer 签名密钥
PHALA_NEO_N3_WIF=
PHALA_NEO_N3_PRIVATE_KEY=
NEO_N3_WIF=
PHALA_NEOX_PRIVATE_KEY=

# Oracle contract hashes / Oracle 与 Feed 合约地址
CONTRACT_MORPHEUS_ORACLE_HASH=
CONTRACT_ORACLE_CALLBACK_CONSUMER_HASH=
CONTRACT_MORPHEUS_DATAFEED_HASH=
CONTRACT_MORPHEUS_ORACLE_X_ADDRESS=
CONTRACT_ORACLE_CALLBACK_CONSUMER_X_ADDRESS=
CONTRACT_MORPHEUS_DATAFEED_X_ADDRESS=
# Legacy compatibility only; prefer `NEO_N3_WIF`.
NEO_TESTNET_WIF=
NEOX_PRIVATE_KEY=
CRON_SECRET=replace-me
