# Auth secrets: NITRO_* names are preferred; PHALA_* equivalents remain supported as fallbacks.
NITRO_API_TOKEN=your-nitro-api-token
NITRO_SHARED_SECRET=your-nitro-shared-secret
NEO_RPC_URL=https://api.n3index.dev/testnet
NEO_NETWORK_MAGIC=894710606
NEOX_RPC_URL=https://neoxt4seed1.ngd.network
NEOX_CHAIN_ID=12227332
# Signer key env names are resolved via the pinned signer allowlist (PHALA_* retained).
PHALA_NEO_N3_WIF=
PHALA_NEO_N3_PRIVATE_KEY=
PHALA_NEOX_PRIVATE_KEY=
CONTRACT_SERVICEGATEWAY_HASH=
CONTRACT_PRICEFEED_HASH=
CONTRACT_RANDOMNESSLOG_HASH=
ORACLE_HTTP_ALLOWLIST=https://api.binance.com,https://api.coinbase.com

# --- Optional hardening / tuning (all have backward-compatible defaults) ---
# Bound the on-demand provider config/response caches (default 500 entries) (C2).
# MORPHEUS_PROVIDER_CACHE_MAX_ENTRIES=500
# Feed timestamp clamp guardrails (B9): hard-reject an upstream observation more
# than N seconds in the future (default 300); clamp a mildly-future value to
# now + skew (default 60s).
# MORPHEUS_FEED_TIMESTAMP_MAX_FUTURE_SECONDS=300
# MORPHEUS_FEED_TIMESTAMP_FUTURE_SKEW_SECONDS=60
# /oracle/decrypt per-request binding (E5): when true, require (chain, contract,
# messageId) binding + on-chain unlockTime re-assertion. Default off (the relayer
# posts only {envelope} after the contract has already gated unlock).
# MORPHEUS_ORACLE_DECRYPT_REQUIRE_BINDING=false
# NeoDID time-locked / recipient message contract (used by the gated decrypt lane
# and recipient reveal). Falls back to NEOX_RPC / NEOX_CHAIN_ID.
# NEOX_MESSAGE_RPC=
# NEOX_MESSAGE_CONTRACT=
# NEOX_MESSAGE_CHAIN_ID=
# NeoDID unverified provider_uid (E3): default true keeps the 9 caller-supplied-uid
# providers working. Set false ONLY as a coordinated rollout to require a
# TEE-verified provider_uid (currently only web3auth derives it in-enclave).
# MORPHEUS_NEODID_ALLOW_UNVERIFIED_UID=true
# Worker /health readiness (F4): when true, /health returns 503 (status:degraded)
# if the signing key / dstack are unreachable or the feed is stale. Default off
# (status stays 'ok'; readiness is reported additively).
# MORPHEUS_WORKER_HEALTH_STRICT=false
# MORPHEUS_HEALTH_FEED_STALE_AFTER_MS=600000
