{
  "name": "@neo-morpheus-oracle/morpheus-relayer",
  "private": true,
  "version": "0.1.0",
  "type": "module",
  "scripts": {
    "start": "node src/cli.js loop",
    "once": "node src/cli.js once",
    "metrics": "node src/cli.js metrics",
    "metrics:prom": "node src/cli.js metrics:prom",
    "serve:metrics": "node src/cli.js serve:metrics",
    "check": "find src \\( -name '*.js' -o -name '*.mjs' \\) -print | sort | xargs -n1 node --check && node --check relayer.test.mjs",
    "test": "node --test relayer.test.mjs src/*.test.mjs src/*/*.test.mjs"
  },
  "dependencies": {
    "@cityofzion/neon-js": "^5.8.1",
    "ethers": "^6.16.0"
  },
  "overrides": {
    "@cityofzion/neon-core": {
      "lodash": "4.18.1"
    }
  }
}
