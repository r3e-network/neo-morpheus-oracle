{
  "root": true,
  "parser": "@typescript-eslint/parser",
  "parserOptions": {
    "ecmaVersion": 2022,
    "sourceType": "module",
    "ecmaFeatures": {
      "jsx": true
    }
  },
  "env": {
    "node": true,
    "es2022": true
  },
  "settings": {
    "react": {
      "version": "detect"
    }
  },
  "ignorePatterns": [
    "node_modules/",
    ".next/",
    ".vercel/",
    "coverage/",
    "contracts/build/",
    "contracts/**/bin/",
    "contracts/**/obj/",
    "contracts/neox/artifacts/",
    "contracts/neox/cache/",
    "contracts/neox/node_modules/",
    "apps/web/.next/",
    "supabase/**",
    "contracts/**",
    "examples/**"
  ],
  "plugins": ["@typescript-eslint"],
  "rules": {
    "no-unused-vars": "off",
    "@typescript-eslint/no-unused-vars": [
      "error",
      { "argsIgnorePattern": "^_", "varsIgnorePattern": "^_" }
    ]
  },
  "overrides": [
    {
      "files": ["*.js", "*.mjs"],
      "parser": null,
      "rules": {
        "no-unused-vars": ["error", { "argsIgnorePattern": "^_" }]
      }
    }
  ]
}
