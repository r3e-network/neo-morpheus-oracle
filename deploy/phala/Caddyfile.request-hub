{
  auto_https off
  admin off
}

:8088 {
  handle /testnet/* {
    reverse_proxy request-worker:8080 {
      header_up X-Morpheus-Network testnet
    }
  }

  handle /mainnet/* {
    reverse_proxy request-worker:8080 {
      header_up X-Morpheus-Network mainnet
    }
  }

  handle {
    reverse_proxy request-worker:8080 {
      header_up X-Morpheus-Network testnet
    }
  }
}
