# Minimal Phala UI / CLI env example.
# Most runtime settings are packed into MORPHEUS_RUNTIME_CONFIG_JSON.
# Generate a real file from local .env via: npm run render:phala-env

MORPHEUS_PHALA_WORKER_IMAGE=ghcr.io/r3e-network/neo-morpheus-oracle-phala-worker:latest
MORPHEUS_RELAYER_IMAGE=ghcr.io/r3e-network/neo-morpheus-oracle-relayer:latest
PHALA_WORKER_PORT=8080

# Shared auth between web/serverless and Phala worker
PHALA_SHARED_SECRET=replace-me
PHALA_API_TOKEN=

# Supabase
NEXT_PUBLIC_SUPABASE_URL=https://your-project.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-anon-key
SUPABASE_URL=https://your-project.supabase.co
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key

# Packed runtime config consumed by worker / relayer inside Phala
MORPHEUS_RUNTIME_CONFIG_JSON={"MORPHEUS_NETWORK":"testnet","NEO_RPC_URL":"https://testnet1.neo.coz.io:443","NEO_NETWORK_MAGIC":"894710606","CONTRACT_MORPHEUS_ORACLE_HASH":"","CONTRACT_ORACLE_CALLBACK_CONSUMER_HASH":"","CONTRACT_MORPHEUS_DATAFEED_HASH":"","PHALA_NEO_N3_WIF":"","MORPHEUS_RELAYER_NEO_N3_WIF":"","NEOX_RPC_URL":"https://neoxt4seed1.ngd.network","NEOX_CHAIN_ID":"12227332","CONTRACT_MORPHEUS_ORACLE_X_ADDRESS":"","CONTRACT_ORACLE_CALLBACK_CONSUMER_X_ADDRESS":"","CONTRACT_MORPHEUS_DATAFEED_X_ADDRESS":"","PHALA_NEOX_PRIVATE_KEY":"","MORPHEUS_RELAYER_NEOX_PRIVATE_KEY":"","TWELVEDATA_API_KEY":"","MORPHEUS_FEED_PROJECT_SLUG":"demo","MORPHEUS_FEED_PROVIDER":"twelvedata","ORACLE_TIMEOUT":"20s","ORACLE_SCRIPT_TIMEOUT_MS":"2000","COMPUTE_SCRIPT_TIMEOUT_MS":"2000","PHALA_USE_DERIVED_KEYS":"true","PHALA_EMIT_ATTESTATION":"true","PHALA_DSTACK_ENDPOINT":"/var/run/dstack.sock","PHALA_ORACLE_KEYSTORE_PATH":"/data/morpheus/oracle-key.json","MORPHEUS_FEED_PROVIDERS":"twelvedata,binance-spot","MORPHEUS_FEED_SYMBOLS":"NEO-USD,GAS-USD,FLM-USD,BTC-USD,ETH-USD,XAU-USD,XAG-USD,OIL-USD,TRX-USD,SOL-USD,BNB-USD","MORPHEUS_FEED_CHANGE_THRESHOLD_BPS":"10","MORPHEUS_FEED_MIN_UPDATE_INTERVAL_MS":"15000","MORPHEUS_FEED_PAIR_REGISTRY_JSON":""}
