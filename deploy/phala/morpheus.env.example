# Minimal Phala UI / CLI env example.
# Most runtime settings are packed into MORPHEUS_RUNTIME_CONFIG_JSON.
# Generate a real file from local .env via: npm run render:phala-env
# For bilingual explanations of the variables, read `docs/ENVIRONMENT.md`.

MORPHEUS_PHALA_WORKER_IMAGE=ghcr.io/r3e-network/neo-morpheus-oracle-phala-worker:latest
MORPHEUS_RELAYER_IMAGE=ghcr.io/r3e-network/neo-morpheus-oracle-relayer:latest
PHALA_WORKER_PORT=8080

# Shared auth between web/serverless and Phala worker
PHALA_SHARED_SECRET=replace-me
PHALA_API_TOKEN=

# Supabase
NEXT_PUBLIC_SUPABASE_URL=https://your-project.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-anon-key
SUPABASE_URL=https://your-project.supabase.co
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key
MORPHEUS_PROVIDER_CONFIG_API_KEY=
MORPHEUS_RELAYER_ADMIN_API_KEY=
MORPHEUS_SIGNING_ADMIN_API_KEY=
MORPHEUS_RELAY_ADMIN_API_KEY=
MORPHEUS_OPERATOR_API_KEY=

# Packed runtime config consumed by worker / relayer inside Phala
MORPHEUS_RUNTIME_CONFIG_JSON={"MORPHEUS_PROVIDER_CONFIG_API_KEY":"","MORPHEUS_RELAYER_ADMIN_API_KEY":"","MORPHEUS_SIGNING_ADMIN_API_KEY":"","MORPHEUS_RELAY_ADMIN_API_KEY":"","MORPHEUS_OPERATOR_API_KEY":"","MORPHEUS_NETWORK":"mainnet","NEO_RPC_URL":"https://mainnet1.neo.coz.io:443","NEO_NETWORK_MAGIC":"860833102","CONTRACT_MORPHEUS_ORACLE_HASH":"0x017520f068fd602082fe5572596185e62a4ad991","CONTRACT_ORACLE_CALLBACK_CONSUMER_HASH":"0xe1226268f2fe08bea67fb29e1c8fda0d7c8e9844","CONTRACT_MORPHEUS_DATAFEED_HASH":"0x03013f49c42a14546c8bbe58f9d434c3517fccab","PHALA_NEO_N3_WIF":"","MORPHEUS_RELAYER_NEO_N3_WIF":"","NEOX_RPC_URL":"https://mainnet-2.rpc.banelabs.org","NEOX_CHAIN_ID":"47763","CONTRACT_MORPHEUS_ORACLE_X_ADDRESS":"","CONTRACT_ORACLE_CALLBACK_CONSUMER_X_ADDRESS":"","CONTRACT_MORPHEUS_DATAFEED_X_ADDRESS":"","PHALA_NEOX_PRIVATE_KEY":"","MORPHEUS_RELAYER_NEOX_PRIVATE_KEY":"","TWELVEDATA_API_KEY":"","MORPHEUS_FEED_PROJECT_SLUG":"demo","MORPHEUS_FEED_PROVIDER":"twelvedata","MORPHEUS_AUTOMATION_ENABLED":"true","MORPHEUS_AUTOMATION_BATCH_SIZE":"50","MORPHEUS_AUTOMATION_MAX_QUEUED_PER_TICK":"10","MORPHEUS_AUTOMATION_PRICE_PAIRS_PER_TICK":"64","MORPHEUS_AUTOMATION_DEFAULT_PRICE_COOLDOWN_MS":"60000","MORPHEUS_RELAYER_NEO_N3_START_BLOCK":"","MORPHEUS_RELAYER_NEO_X_START_BLOCK":"","ORACLE_TIMEOUT":"20s","ORACLE_SCRIPT_TIMEOUT_MS":"2000","ORACLE_WASM_TIMEOUT_MS":"30000","COMPUTE_SCRIPT_TIMEOUT_MS":"2000","COMPUTE_WASM_TIMEOUT_MS":"30000","MORPHEUS_WASM_TIMEOUT_MS":"30000","PHALA_USE_DERIVED_KEYS":"true","PHALA_EMIT_ATTESTATION":"true","PHALA_DSTACK_ENDPOINT":"/var/run/dstack.sock","PHALA_ORACLE_KEYSTORE_PATH":"/data/morpheus/oracle-key.json","MORPHEUS_FEED_PROVIDERS":"twelvedata","MORPHEUS_FEED_SYMBOLS":"TWELVEDATA:NEO-USD,TWELVEDATA:GAS-USD,TWELVEDATA:FLM-USD,TWELVEDATA:BTC-USD,TWELVEDATA:ETH-USD,TWELVEDATA:SOL-USD,TWELVEDATA:TRX-USD,TWELVEDATA:PAXG-USD,TWELVEDATA:WTI-USD,TWELVEDATA:BRENT-USD,TWELVEDATA:NATGAS-USD,TWELVEDATA:COPPER-USD,TWELVEDATA:WHEAT-USD,TWELVEDATA:CORN-USD,TWELVEDATA:SOY-USD,TWELVEDATA:USDT-USD,TWELVEDATA:USDC-USD,TWELVEDATA:BNB-USD,TWELVEDATA:XRP-USD,TWELVEDATA:DOGE-USD,TWELVEDATA:AAPL-USD,TWELVEDATA:GOOGL-USD,TWELVEDATA:MSFT-USD,TWELVEDATA:AMZN-USD,TWELVEDATA:TSLA-USD,TWELVEDATA:META-USD,TWELVEDATA:NVDA-USD,TWELVEDATA:SPY-USD,TWELVEDATA:QQQ-USD,TWELVEDATA:GLD-USD,TWELVEDATA:EUR-USD,TWELVEDATA:GBP-USD,TWELVEDATA:JPY-USD,TWELVEDATA:CNY-USD","MORPHEUS_FEED_CHANGE_THRESHOLD_BPS":"10","MORPHEUS_FEED_MIN_UPDATE_INTERVAL_MS":"60000","MORPHEUS_FEED_SYNC_INTERVAL_MS":"60000","MORPHEUS_FEED_PAIR_REGISTRY_JSON":""}
