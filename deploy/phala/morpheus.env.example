# Image tags
MORPHEUS_PHALA_WORKER_IMAGE=ghcr.io/r3e-network/neo-morpheus-oracle-phala-worker:latest
MORPHEUS_RELAYER_IMAGE=ghcr.io/r3e-network/neo-morpheus-oracle-relayer:latest

# Worker
PHALA_WORKER_PORT=8080
PHALA_SHARED_SECRET=replace-me
PHALA_API_TOKEN=
TWELVEDATA_API_KEY=

# Supabase
NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_ANON_KEY=
SUPABASE_URL=
SUPABASE_SERVICE_ROLE_KEY=
MORPHEUS_PROVIDER_CONFIG_API_KEY=

# Network registry selection
MORPHEUS_NETWORK=testnet

# Neo N3
NEO_RPC_URL=https://testnet1.neo.coz.io:443
NEO_NETWORK_MAGIC=894710606
CONTRACT_MORPHEUS_ORACLE_HASH=
CONTRACT_ORACLE_CALLBACK_CONSUMER_HASH=
CONTRACT_MORPHEUS_DATAFEED_HASH=
PHALA_NEO_N3_WIF=
PHALA_NEO_N3_PRIVATE_KEY=
MORPHEUS_RELAYER_NEO_N3_WIF=
MORPHEUS_RELAYER_NEO_N3_PRIVATE_KEY=

# Neo X
NEOX_RPC_URL=https://neoxt4seed1.ngd.network
NEOX_CHAIN_ID=12227332
CONTRACT_MORPHEUS_ORACLE_X_ADDRESS=
CONTRACT_ORACLE_CALLBACK_CONSUMER_X_ADDRESS=
CONTRACT_MORPHEUS_DATAFEED_X_ADDRESS=
PHALA_NEOX_PRIVATE_KEY=
MORPHEUS_RELAYER_NEOX_PRIVATE_KEY=

# Feed defaults
MORPHEUS_FEED_PROJECT_SLUG=demo
MORPHEUS_FEED_PROVIDER=twelvedata

# Relayer ops
MORPHEUS_RELAYER_POLL_INTERVAL_MS=5000
MORPHEUS_RELAYER_CONCURRENCY=4
MORPHEUS_RELAYER_MAX_BLOCKS_PER_TICK=250
MORPHEUS_RELAYER_MAX_RETRIES=5
MORPHEUS_RELAYER_RETRY_BASE_DELAY_MS=5000
MORPHEUS_RELAYER_RETRY_MAX_DELAY_MS=300000
MORPHEUS_RELAYER_PROCESSED_CACHE_SIZE=5000
MORPHEUS_RELAYER_DEAD_LETTER_LIMIT=500
MORPHEUS_RELAYER_LOG_FORMAT=json
MORPHEUS_RELAYER_LOG_LEVEL=info
