# /opt/morpheus/nitro/feed-pusher.env  (chmod 600) — DO NOT COMMIT REAL VALUES
TD_KEY=<twelvedata-api-key>
RUNTIME_TOKEN=<copied from MORPHEUS_RUNTIME_TOKEN in morpheus-relayer.env>
FEED_RPC=https://mainnet1.neo.coz.io:443
FEED_RPCS=https://api.n3index.dev/mainnet,https://rpc10.n3.nspcc.ru:10331,https://mainnet1.neo.coz.io:443
THRESHOLD_BPS=10
MAX_STALE_SEC=1800
# Price-sanity guard: reject a candidate that deviates from the existing on-chain
# price by more than MAX_DEVIATION_BPS (5000 = 50%). Bootstrap writes (no on-chain
# price yet) and zero/negative quotes are handled separately. Set to 0 to bypass
# for a genuine flash move (e.g. a real >50% candle), then re-set.
MAX_DEVIATION_BPS=5000
GAS_WARN=8
# SYMBOLS = the full Neo N3 feed (NeoVM updater gas is cheap, so it carries forex/oil too).
# Neo X (EVM) pushes real gas every 2 min, so it runs a CRYPTO-ONLY subset via NEOX_SYMBOLS
# (TradFi forex EUR/GBP/JPY/CNY + WTI oil dropped). If NEOX_SYMBOLS is unset, Neo X falls
# back to the full SYMBOLS. PAXG (tokenized-gold ERC20) is kept as a crypto asset.
SYMBOLS=NEO-USD,GAS-USD,FLM-USD,BTC-USD,ETH-USD,SOL-USD,TRX-USD,PAXG-USD,WTI-USD,USDT-USD,USDC-USD,BNB-USD,XRP-USD,DOGE-USD,EUR-USD,GBP-USD,JPY-USD,CNY-USD
NEOX_SYMBOLS=NEO-USD,GAS-USD,FLM-USD,BTC-USD,ETH-USD,SOL-USD,TRX-USD,BNB-USD,XRP-USD,DOGE-USD,USDT-USD,USDC-USD,PAXG-USD

# ── feed-monitor.mjs (morpheus-feed-monitor.timer) ────────────────────────────
# Per-pair staleness: the monitor reads the FULL on-chain registry (getAllFeedRecords)
# and checks every pair, not just NEO-USD. Optional Prometheus node_exporter
# textfile output (off unless set to a path under the textfile-collector dir):
# emits feed_age_seconds{pair,network} + feed_updater_gas{network}.
MONITOR_PROM_TEXTFILE=
# Metric network label (this monitor watches Neo N3).
MONITOR_NETWORK=neo-n3
# TradFi pairs (forex/commodities) don't trade on weekends/holidays, so their
# staleness window widens to TRADFI_WEEKEND_AGE_SEC while the market is closed
# (avoids false weekend alerts). Crypto pairs keep MAX_AGE_SEC year-round.
TRADFI_PAIRS=EUR-USD,GBP-USD,JPY-USD,CNY-USD,WTI-USD
TRADFI_WEEKEND_AGE_SEC=270000
# Extra UTC holiday dates (YYYY-MM-DD, comma list) when TradFi markets close mid-week.
TRADFI_HOLIDAYS=

# /opt/morpheus/nitro/feed-topup.env (chmod 600, generated on box) — funding key for auto-topup
TOPUP_WIF=<dedicated low-value funding key, generated on box, never committed>
TOPUP_THRESHOLD=25
TOPUP_AMOUNT=40
