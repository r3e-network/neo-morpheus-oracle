# Morpheus Nitro compute worker (separate from the 8787 enclave signer).
# The relayer reaches it via NITRO_API_URL=http://127.0.0.1:8788 while signing
# stays on the enclave via NITRO_SIGNER_URL=http://127.0.0.1:8787.
PORT=8788
# Auth secret the relayer presents (must equal the relayer's MORPHEUS_RUNTIME_TOKEN).
NITRO_API_TOKEN=__SET_ME__
AWS_REGION=us-east-1
# Key material for privacy/seal + neodid lanes (AWS Secrets Manager, read via the box instance role).
NITRO_X25519_SECRET_ID=morpheus/x25519-wrap
NITRO_NEODID_SALT_SECRET_ID=morpheus/neodid-salt
MORPHEUS_ALLOW_EPHEMERAL_KEY=false
