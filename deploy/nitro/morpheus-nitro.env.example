# Copy this file to /opt/morpheus/nitro/morpheus-nitro.env on the Nitro host.
# Do not commit the real file. It contains only host-side config. Nitro CLI
# cannot pass runtime env files into enclaves; signer secrets must be sealed
# with KMS/attestation and decrypted from inside the enclave.

MORPHEUS_NETWORK=mainnet
MORPHEUS_NITRO_IMAGE=morpheus-nitro-signer:latest
MORPHEUS_NITRO_EIF=/opt/morpheus/nitro/morpheus-nitro-signer.eif
MORPHEUS_NITRO_CID=16
MORPHEUS_NITRO_CPU_COUNT=2
MORPHEUS_NITRO_MEMORY_MIB=1024
MORPHEUS_NITRO_HOST_PORT=8787
MORPHEUS_NITRO_VSOCK_PORT=8787

# Relayer talks to the local host proxy, which forwards to the enclave over vsock.
MORPHEUS_RUNTIME_URL=http://127.0.0.1:8787
PHALA_API_URL=http://127.0.0.1:8787
PHALA_USE_DERIVED_KEYS=true
