# This is the plaintext shape before KMS sealing. Do not copy plaintext into a
# running parent host service. Seal it with KMS/attestation and decrypt only from
# inside the enclave.

MORPHEUS_NETWORK=mainnet
PORT=8080
NITRO_SIGNER_VSOCK_PORT=8787

# Shared runtime auth token used by the relayer when calling /sign/payload.
NITRO_SIGNER_TOKEN=
MORPHEUS_RUNTIME_TOKEN=

# Must match config/signer-identities.json for mainnet updater/oracle_verifier.
MORPHEUS_UPDATER_NEO_N3_WIF_MAINNET=
MORPHEUS_UPDATER_NEO_N3_PRIVATE_KEY_MAINNET=
MORPHEUS_ORACLE_VERIFIER_WIF_MAINNET=
MORPHEUS_ORACLE_VERIFIER_PRIVATE_KEY_MAINNET=
