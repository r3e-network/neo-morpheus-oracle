# Neo X oracle fulfiller config (copy to /opt/morpheus/nitro/neox-fulfiller.env)
NEOX_ORACLE=0xeCFC1C652B5cCdBfe3E9314a83156787D92a3fD2
NEOX_RPC=https://mainnet-1.rpc.banelabs.org
NEOX_CHAIN_ID=47763
# updater sends fulfillRequest (gas payer); verifier signs the result digest.
# Single key is fine (updater==verifier==oracle owner). Rotate from the deploy key.
NEOX_UPDATER_PK=0x_REPLACE_ME
# NEOX_VERIFIER_PK=0x_optional_separate_signer
FULFILLER_STATE=/opt/morpheus/nitro/neox-fulfiller-state.json
POLL_MS=5000
LOOKBACK_BLOCKS=5000
# optional HTTP/compute lanes via the Nitro worker:
# NEOX_WORKER_URL=http://127.0.0.1:8788
# NEOX_WORKER_TOKEN=...
